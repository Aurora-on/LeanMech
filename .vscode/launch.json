{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Pipeline: Run Selected Config (Terminal)",
      "type": "python",
      "request": "launch",
      "module": "mech_pipeline.cli",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "PYTHONUNBUFFERED": "1",
        "PYTHONIOENCODING": "utf-8"
      },
      "args": [
        "run",
        "--config",
        "${input:pipelineConfig}",
        "--sample-concurrency",
        "${input:sampleConcurrency}"
      ]
    },
    {
      "name": "Pipeline: 4-Sample Real API (Terminal)",
      "type": "python",
      "request": "launch",
      "module": "mech_pipeline.cli",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "justMyCode": true,
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "PYTHONUNBUFFERED": "1",
        "PYTHONIOENCODING": "utf-8"
      },
      "args": [
        "run",
        "--config",
        "configs/mechanics73_plus3_proxy_gpt54_seed2026033001.yaml",
        "--sample-concurrency",
        "4"
      ]
    }
  ],
  "inputs": [
    {
      "id": "pipelineConfig",
      "type": "pickString",
      "description": "Choose pipeline config",
      "default": "configs/default_mechanics73_openai.yaml",
      "options": [
        "configs/default_mechanics73_openai.yaml",
        "configs/mechanics73_plus3_proxy_gpt54_seed2026033001.yaml",
        "configs/mechanics73_plus3_proxy_gpt54.yaml",
        "configs/mechanics73_plus3_openai_gpt54.yaml",
        "configs/full_run_openai_proxy_lean.yaml"
      ]
    },
    {
      "id": "sampleConcurrency",
      "type": "pickString",
      "description": "Choose sample concurrency",
      "default": "4",
      "options": [
        "1",
        "2",
        "4",
        "8",
        "10"
      ]
    }
  ]
}
